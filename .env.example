# Example environment for an instantiated product. Copy to .env (gitignored) and fill. NO secrets here.
# Most products are static-replay and need NONE of this (the app/ backend is dormant). These vars only matter
# when app/ is activated (ADR-0002 trigger).
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
# CORS origins for the SPA (comma-separated)
DEV_ORIGINS=http://localhost:5173
PROD_ORIGINS=
# where the built SPA + the committed artifacts live (relative to repo root)
FRONTEND_DIST=frontend/dist
DATA_DIR=data/derived
