# Minimal-but-complete ignore for an instantiated product repo (ADR-0057).

# --- Python virtualenvs (ANY name, ANY depth) — NEVER committed; recreate via scripts/setup ---
.venv/
.venv*
**/.venv*
venv/
**/venv/

# --- Python caches / build ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
build/
dist/

# --- Node / web ---
node_modules/
frontend/dist/
frontend/.vite/
.vite
*.local
# build-time overlay generated by frontend/copy-data.mjs (canonical copies live in data/derived)
frontend/public/data/
frontend/public/ae.onnx
frontend/public/cnn.onnx
frontend/public/tw-accel.bin
frontend/public/tw-linear.bin
frontend/public/tw-seasonal.bin
frontend/public/tw-stable.bin
frontend/public/tw-step.bin
frontend/public/tw-cases.json
frontend/public/forecast-benchmark.json
*.tsbuildinfo

# --- Raw / heavy data — commit ONLY the compact derived artifacts under data/derived/ ---
# the synthetic Sentinel-1 scenes (168 MB of .h5) are regenerable from the forward sim — NEVER committed
data/raw/
*.h5
*.hdf5
*.parquet
*.nc
*.npy

# --- Secrets / env (public repo — only .env.example is committed) ---
.env
.env.*
!.env.example

# large trained models stay local/LFS; commit small ONNX explicitly
models/*.pt
models/*.pth
*.dll
*.so
*.dylib

# --- OS / logs ---
.DS_Store
Thumbs.db
*.log
